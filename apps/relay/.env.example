# ── Spirit Relay Server Environment ──────────────────────────────────────────

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spirit

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED: At least 32-character random secret. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-secret-at-least-32-chars

# Token expiry (Vercel-style duration strings)
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=30d

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DURATION=86400    # 24 hours in seconds
NONCE_EXPIRY=300          # 5 minutes in seconds

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * for all
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60         # requests per window
RATE_LIMIT_WINDOW=60000   # window size in ms (1 minute)

# ── Relay ─────────────────────────────────────────────────────────────────────
RELAY_MAX_MESSAGE_TTL=300   # max message TTL in seconds
RELAY_MAX_SUBSCRIPTIONS=100 # max topics per WebSocket client
