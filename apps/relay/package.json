{
  "name": "@spirit-protocol/relay",
  "version": "0.1.0",
  "description": "Spirit Protocol – self-hosted relay server (Fastify + WebSocket)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
