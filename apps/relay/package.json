    "@fastify/helmet": "^11.1.1",
    "fastify": "^4.26.2",
    "jose": "^5.2.4",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4",
    "pino": "^8.18.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.0",
